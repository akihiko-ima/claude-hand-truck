[grid]
rows = 3
cols = 7
clean_threshold_seconds = 3.0

[hand_detection]
right_hand_only = true
num_hands = 2
min_detection_confidence = 0.5
min_presence_confidence = 0.5
min_tracking_confidence = 0.5

[pipeline]
target_fps = 25.0
frame_queue_maxsize = 300
priority_camera_id = 0
camera_ids = [0, 1]

[csv]
enabled = true
output_path = "logs/hand_landmarks.csv"

[zmq]
enabled = true
endpoint = "tcp://*:5555"

[zmq_receiver]
enabled = true
endpoint = "tcp://*:5556"
